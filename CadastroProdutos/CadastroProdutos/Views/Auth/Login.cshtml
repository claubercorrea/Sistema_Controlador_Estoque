@model CadastroProdutos.DTO.LoginDto

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center align-items-center" style="min-height: 65vh;">
    <div class="col-md-4">

        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show small mb-3" role="alert">
                <strong>Sucesso!</strong> @TempData["MensagemSucesso"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

       

        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-4">
                <h3 class="text-center fw-bold text-secondary mb-4">Acesso ao Sistema</h3>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small p-2"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-bold text-muted">E-mail Corporativo</label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="nome@empresa.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Senha" class="form-label small fw-bold text-muted">Senha de Acesso</label>
                        <input asp-for="Senha" type="password" class="form-control form-control-lg" placeholder="••••••••" />
                        <span asp-validation-for="Senha" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm">Entrar no Painel</button>
                </form>

            </div>
        </div>
    </div>
</div>