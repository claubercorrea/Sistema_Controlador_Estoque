@model List<CadastroProdutos.DTO.ExibirUsuarioDto>
@{
    ViewData["Title"] = "Painel Administrativo";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h2 text-dark font-weight-bold">Painel de Controle</h1>
            <p class="text-muted mb-0">Gestão de acessos corporativos e envio de relatórios comerciais.</p>
        </div>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a asp-controller="Estoque" asp-action="Index" class="btn btn-outline-primary d-flex align-items-center gap-2">
                <i class="bi bi-box-seam"></i> Ir para o Estoque
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm border-start border-primary border-4 h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary"><i class="bi bi-envelope-paper"></i> Relatório por E-mail</h5>
                    <p class="card-text text-muted small">Gere o relatório consolidado via EF Core em formato PDF e envie diretamente para o remetente.</p>

                    <form asp-controller="Estoque" asp-action="EnviarPdfEmail" method="post" class="d-flex gap-2">
                        <select name="categoriaSelecionada" class="form-select form-select-sm">
                            <option value="">Todas as Categorias</option>
                            <option value="Eletrônicos">Eletrônicos</option>
                            <option value="Alimentos">Alimentos</option>
                            <option value="Limpeza">Limpeza</option>
                        </select>
                        <button type="submit" class="btn btn-primary btn-sm px-3 d-flex align-items-center gap-1">
                            <i class="bi bi-send"></i> Disparar
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-8">
            <div class="card shadow-sm h-100">
                <div class="card-body bg-light d-flex align-items-center">
                    <div class="row w-100 text-center">
                        <div class="col border-end">
                            <h3 class="text-dark fw-bold mb-0">@Model.Count</h3>
                            <span class="text-muted small">Usuários Registrados</span>
                        </div>
                        <div class="col border-end">
                            <h3 class="text-warning fw-bold mb-0">@Model.Count(u => u.PrimeiroAcesso)</h3>
                            <span class="text-muted small">Acessos Pendentes</span>
                        </div>
                        <div class="col">
                            <h3 class="text-success fw-bold mb-0">@Model.Count(u => !u.PrimeiroAcesso)</h3>
                            <span class="text-muted small">Contas Ativas</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-people-fill me-2"></i> Usuários do Sistema</h5>
            <a asp-action="Cadastrar" class="btn btn-success btn-sm d-flex align-items-center gap-1">
                <i class="bi bi-person-plus-fill"></i> Novo Operador
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-light text-secondary small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 80px;">Avatar</th>
                            <th>E-mail Corporativo</th>
                            <th>Nível de Acesso</th>
                            <th>Status da Conta</th>
                            <th class="text-end pe-4" style="width: 200px;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var usuario in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(usuario.FotoUrl))
                                    {
                                        <img src="@usuario.FotoUrl" class="rounded-circle border" width="38" height="38" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center border fw-bold" style="width: 38px; height: 38px;">
                                            @usuario.Email.Substring(0, 2).ToUpper()
                                        </div>
                                    }
                                </td>
                                <td>
                                    <span class="fw-semibold text-dark">@usuario.Email</span>
                                </td>
                                <td>
                                    <form asp-action="AlterarNivelAcesso" method="post" class="d-inline-block">
                                        <input type="hidden" name="userId" value="@usuario.Id" />
                                        <select name="novaRole" onchange="this.form.submit()" class="form-select form-select-sm border-0 bg-light py-1 fw-medium" style="width: 140px;">
                                            <option value="Admin" selected="@(usuario.Role == "Admin")">Administrador</option>
                                            <option value="Funcionario" selected="@(usuario.Role == "Funcionario")">Funcionário</option>
                                        </select>
                                    </form>
                                </td>
                                <td>
                                    @if (usuario.PrimeiroAcesso)
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2.5 py-1.5 rounded-pill small">
                                            <i class="bi bi-clock-history me-1"></i> Primeiro Acesso
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1.5 rounded-pill small">
                                            <i class="bi bi-check-circle me-1"></i> Confirmado
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-outline-danger btn-sm" title="Bloquear Usuário">
                                        <i class="bi bi-person-x"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .gap-2 {
        gap: 0.5rem !important;
    }

    .gap-1 {
        gap: 0.25rem !important;
    }

    .bg-warning-subtle {
        background-color: #fff3cd !important;
    }

    .text-warning {
        color: #856404 !important;
    }

    .bg-success-subtle {
        background-color: #d1e7dd !important;
    }

    .text-success {
        color: #0f5132 !important;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">