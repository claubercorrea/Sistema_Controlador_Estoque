@model CadastroProdutos.DTO.ProdutoDto

@{
    ViewData["Title"] = "Cadastrar Produto";
}

<h2 class="mt-4">Cadastrar Novo Produto</h2>

<form asp-controller="Estoque" asp-action="SalvarProduto" method="post" class="mt-3">

    <div class="mb-3">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" placeholder="Ex: Monitor Gamer" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Quantidade" class="form-label"></label>
            <input asp-for="Quantidade" type="number" class="form-control" />
            <span asp-validation-for="Quantidade" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Preco" class="form-label"></label>
            <input asp-for="Preco" type="number" step="0.01" class="form-control" placeholder="0.00" />
            <span asp-validation-for="Preco" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Categoria" class="form-label"></label>
        <input asp-for="Categoria" class="form-control" />
        <span asp-validation-for="Categoria" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Codigo_Barra" class="form-label"></label>
        <input asp-for="Codigo_Barra" type="number"  class="form-control"  required/>
    </div>
 
    <button type="submit" class="btn btn-primary">Salvar Produto</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }
